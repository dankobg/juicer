{
	"name": "juicer-web",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"build-dev": "vite build --mode development",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"gen:proto": "buf generate ../proto/juicer",
		"gen:openapi": "openapi-typescript --enum ../api/schema/juicer.yaml -o ./src/lib/gen/juicer_openapi.ts",
		"gen": "pnpm gen:openapi && pnpm gen:proto"
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.70.0",
		"@bufbuild/protobuf": "^2.12.0",
		"@bufbuild/protoc-gen-es": "^2.12.0",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.18.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25.9.3",
		"@vitest/browser": "^4.1.8",
		"@vitest/browser-playwright": "^4.1.8",
		"bits-ui": "2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"formsnap": "^2.0.1",
		"globals": "^17.6.0",
		"layerchart": "2.0.0-next.27",
		"openapi-typescript": "^7.13.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.16",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@dankop/juicer-board": "^1.11.2",
		"@ory/client-fetch": "^1.22.37",
		"just-safe-set": "^4.2.1",
		"mode-watcher": "^1.1.0",
		"openapi-fetch": "^0.17.0",
		"runed": "^0.37.1",
		"valibot": "^1.4.1"
	}
}
